{
  "name": "@like2d/like-scenes",
  "version": "1.0.0",
  "description": "Scene management system for Like2D",
  "exports": {
    ".": "./src/index.ts",
    "./prefab/*": "./src/prefab/*.ts"
  },
  "imports": {
    "like2d": "jsr:@like2d/like"
  },
  "publish": {
    "include": [
      "src/**/*.ts",
      "README.md",
      "LICENSE"
    ],
    "exclude": [
      "**/*.test.ts",
      "**/*.md"
    ]
  }
}
