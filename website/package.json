{
  "name": "website",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "typedoc --options typedoc.json",
    "preview": "npx serve public",
    "dev": "npm run build && concurrently \"npm run build:watch\" \"npm run serve:watch\"",
    "build:watch": "typedoc --options typedoc.json --watch",
    "serve:watch": "browser-sync public --watch --port 3000",
    "docs:generate": "typedoc --options typedoc.json",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "lint": "echo 'No linting configured'",
    "deploy": "pnpm build && gh-pages -d public"
  },
  "devDependencies": {
    "browser-sync": "^3.0.4",
    "concurrently": "^9.2.1",
    "gh-pages": "^6.3.0",
    "typedoc": "^0.28.17",
    "typedoc-plugin-markdown": "^4.10.0",
    "typedoc-plugin-redirect": "^1.3.0",
    "typescript": "^5.9.3"
  }
}
