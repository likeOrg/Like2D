{
  "name": "website",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "typedoc --options typedoc.json",
    "preview": "npx serve dist",
    "docs:generate": "typedoc --options typedoc.json",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "lint": "echo 'No linting configured'",
    "deploy": "pnpm build && cp index.html dist/ && gh-pages -d dist"
  },
  "devDependencies": {
    "gh-pages": "^6.3.0",
    "typedoc": "^0.28.17",
    "typedoc-plugin-markdown": "^4.10.0",
    "typescript": "^5.9.3"
  }
}
