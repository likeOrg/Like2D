{
  "name": "like2d",
  "version": "2.12.1",
  "description": "A web-native game framework inspired by Love2D",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./math": {
      "import": "./dist/math/index.js",
      "types": "./dist/math/index.d.ts"
    },
    "./prefab-scenes": {
      "import": "./dist/prefab-scenes/index.js",
      "types": "./dist/prefab-scenes/index.d.ts"
    },
    "./graphics": {
      "types": "./dist/graphics/index.d.ts"
    },
    "./audio": {
      "import": "./dist/audio/index.js",
      "types": "./dist/audio/index.d.ts"
    },
    "./input": {
      "import": "./dist/input/index.js",
      "types": "./dist/input/index.d.ts"
    },
    "./timer": {
      "import": "./dist/timer/index.js",
      "types": "./dist/timer/index.d.ts"
    }
  },
  "files": [
    "dist/**/*",
    "!dist/**/*.ts.map",
    "assets/**/*",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "echo 'No linting configured'",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "bench": "vitest bench"
  },
  "keywords": [
    "game",
    "framework",
    "2d",
    "love2d",
    "canvas",
    "web",
    "typescript"
  ],
  "author": "",
  "license": "MIT",
  "homepage": "https://likeorg.github.io/Like2D/",
  "repository": {
    "type": "git",
    "url": "https://github.com/likeOrg/Like2D"
  },
  "devDependencies": {
    "typescript": "^5.9.3"
  }
}
