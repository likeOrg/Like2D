{
  "name": "like2d",
  "version": "2.9.0",
  "description": "A web-native game framework inspired by Love2D",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./scene": {
      "import": "./dist/scene.js",
      "types": "./dist/scene.d.ts"
    },
    "./math": {
      "import": "./dist/math/index.js",
      "types": "./dist/math/index.d.ts"
    },
    "./prefab-scenes": {
      "import": "./dist/prefab-scenes/index.js",
      "types": "./dist/prefab-scenes/index.d.ts"
    },
    "./gamepad": {
      "import": "./dist/gamepad/index.js",
      "types": "./dist/gamepad/index.d.ts"
    },
    "./graphics": {
      "import": "./dist/graphics/index.js",
      "types": "./dist/graphics/index.d.ts"
    },
    "./audio": {
      "import": "./dist/audio/index.js",
      "types": "./dist/audio/index.d.ts"
    },
    "./input": {
      "import": "./dist/input/index.js",
      "types": "./dist/input/index.d.ts"
    },
    "./timer": {
      "import": "./dist/timer/index.js",
      "types": "./dist/timer/index.d.ts"
    },
    "./events": {
      "import": "./dist/events.js",
      "types": "./dist/events.d.ts"
    },
    "./like": {
      "import": "./dist/like.js",
      "types": "./dist/like.d.ts"
    },
    "./engine": {
      "import": "./dist/engine.js",
      "types": "./dist/engine.d.ts"
    }
  },
  "files": [
    "dist/**/*",
    "assets/**/*",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc && cp src/gamecontrollerdb.txt dist/",
    "typecheck": "tsc --noEmit",
    "lint": "echo 'No linting configured'",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "bench": "vitest bench"
  },
  "keywords": [
    "game",
    "framework",
    "2d",
    "love2d",
    "canvas",
    "web",
    "typescript"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/44100hertz/Like2D"
  },
  "devDependencies": {
    "typescript": "^5.9.3"
  }
}
