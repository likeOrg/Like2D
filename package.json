{
  "name": "like2d-workspace",
  "version": "1.0.0",
  "description": "A web-native game framework inspired by Love2D",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter feature-test dev",
    "dev:website": "pnpm --filter website dev",
    "build": "pnpm -r build",
    "build:lib": "pnpm --filter like build",
    "build:website": "pnpm --filter website build",
    "preview:website": "pnpm --filter website preview",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "publish:lib": "pnpm build:lib && cd like && npm publish",
    "update-gamepad-db": "curl -o like/src/gamecontrollerdb.txt https://raw.githubusercontent.com/gabomdq/SDL_GameControllerDB/master/gamecontrollerdb.txt",
    "clean": "pnpm -r exec rm -rf dist node_modules/.cache"
  },
  "devDependencies": {
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.1.0"
  }
}
